# =============================================================================
# LucidOS .gitignore
# =============================================================================
# Specifies files and directories that should NOT be tracked by git.
# This prevents large build artifacts and temporary files from being committed.
# =============================================================================

# --- live-build build output ---
# These directories are created during the build process and can be large (10+ GB).
# They are regenerated by running 'lb build', so don't commit them.
live-build/chroot/
live-build/binary/
live-build/build/

# Live-build staging/cache directory
# Contains downloaded packages (can be 3-8 GB).
# Delete with: lb clean --cache
# Do NOT delete unless you want to re-download everything.
live-build/cache/

# Live-build log files (regenerated on each build)
live-build/*.log
live-build/build.log

# Live-build config generated files (recreated by lb config)
live-build/config/binary
live-build/config/bootstrap
live-build/config/chroot
live-build/config/common
live-build/config/source
live-build/.build/

# --- Built ISO files ---
# The final ISO is in dist/ - it's large (1.5-3 GB) and regenerated by the build.
# You may want to track the dist/ directory in a release branch, but not main.
dist/
*.iso
*.hybrid.iso

# --- OS generated files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Editor and IDE files ---
.vscode/
.idea/
*.swp
*.swo
*~
\#*\#
.#*

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
venv/
.venv/
env/
.env/

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Build tools ---
*.o
*.a
*.so
*.d
Makefile.local

# --- Temporary files ---
*.tmp
*.temp
/tmp/
/scratch/

# --- Agent logs (runtime, not source) ---
# The logs directory is tracked (for the .gitkeep), but not the log files themselves
live-build/config/includes.chroot/opt/lucidos-agent/logs/*.log

# --- Secrets and credentials ---
# NEVER commit these - this is a safety net
*.env
.env.local
.env.production
*.key
*.pem
*.pfx
credentials
secrets.json
api_keys.txt

# --- Large binary assets ---
# Large PNG/JPEG wallpapers should go in a separate assets branch or LFS
*.psd
*.ai
*.sketch
# SVG files ARE tracked (they're text-based and version-control friendly)
# *.svg  <-- DO NOT add this line - we want SVGs tracked

# Note: The lucidos-wallpaper.svg is tracked because it's a critical asset.
# If wallpapers get very large in future, consider git-lfs:
#   git lfs track "*.png" "*.jpg"
