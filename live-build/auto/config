#!/bin/sh
# =============================================================================
# LucidOS live-build auto/config
# =============================================================================
# This script is executed by lb config from the live-build directory.
# Keep it to options supported by the live-build version used in CI.
# =============================================================================

set -e

# Security repositories are disabled for now because the live-build
# defaults on Ubuntu 22.04 generate an invalid bookworm/updates entry.
# Re-enable them after we verify the exact Debian security suite mapping
# for this live-build version.
lb config noauto \
    --mode "debian" \
    --distribution "bookworm" \
    --architectures "amd64" \
    --mirror-bootstrap "http://deb.debian.org/debian/" \
    --mirror-chroot "http://deb.debian.org/debian/" \
    --mirror-binary "http://deb.debian.org/debian/" \
    --keyring-packages "debian-archive-keyring" \
    --archive-areas "main contrib non-free-firmware" \
    --security "false" \
    --binary-images "iso-hybrid" \
    --bootappend-live "boot=live components quiet splash hostname=lucid username=lucid locales=en_US.UTF-8 keyboard-layouts=us" \
    --bootappend-install "boot=live components quiet splash hostname=lucid username=lucid locales=en_US.UTF-8 keyboard-layouts=us lucid_install=1" \
    --compression "xz" \
    --cache "true" \
    --iso-volume "LucidLinux" \
    --iso-application "Lucid Linux Alpha 0.2" \
    --iso-publisher "Lucid Linux Project" \
    "${@}"

echo ""
echo "[Lucid Linux] live-build configuration complete."
echo "[Lucid Linux] Run 'sudo lb build' to build the ISO."
