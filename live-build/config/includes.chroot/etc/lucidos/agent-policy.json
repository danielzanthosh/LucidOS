{
  "_comment": "LucidOS Agent Policy â€” /etc/lucidos/agent-policy.json",
  "_description": "This is the SYSTEM-LEVEL policy file for the Lucid Agent. It defines what commands the agent is allowed to execute, which require user confirmation, and which are completely blocked. This file is read by safe-runner.sh and the agent itself. Do not edit unless you understand the security implications.",
  "_version": "0.1.0",
  "_last_updated": "LucidOS Alpha 0.1",

  "policy_name": "LucidOS Default Agent Policy",
  "policy_version": "0.1",
  "policy_description": "Conservative default policy for the Lucid Agent. Safe for general use.",

  "settings": {
    "log_all_commands": true,
    "log_file": "/opt/lucidos-agent/logs/actions.log",
    "log_fallback_file": "/tmp/lucidos-agent-actions.log",
    "require_confirmation_default": true,
    "auto_block_root_commands": true,
    "max_command_length": 2048
  },

  "allowed_without_confirmation": {
    "_comment": "These commands are safe read-only operations. No confirmation needed.",
    "commands": [
      "pwd",
      "whoami",
      "uname",
      "uname -a",
      "uname -r",
      "hostname",
      "date",
      "uptime",
      "echo",
      "id",
      "groups"
    ],
    "command_prefixes": [
      "ls",
      "df",
      "free",
      "ps",
      "top",
      "htop",
      "cat /proc/",
      "cat /sys/",
      "cat /etc/os-release",
      "cat /etc/hostname",
      "cat /etc/hosts",
      "find /home/ -name",
      "grep",
      "which",
      "type",
      "man",
      "help",
      "env",
      "printenv",
      "lsb_release",
      "lsblk",
      "lspci",
      "lsusb",
      "ip addr",
      "ip route",
      "ping",
      "nslookup",
      "dig"
    ],
    "notes": "cat is only safe for /proc/, /sys/, and known safe paths. cat on ~/.ssh/, /etc/shadow, or similar MUST be blocked."
  },

  "requires_confirmation": {
    "_comment": "These commands change system state. The agent must ask the user before running them.",
    "command_prefixes": [
      "apt",
      "apt-get",
      "apt install",
      "apt remove",
      "apt upgrade",
      "apt autoremove",
      "dpkg",
      "systemctl",
      "service",
      "journalctl",
      "git clone",
      "git pull",
      "git push",
      "npm install",
      "npm run",
      "pip install",
      "pip3 install",
      "python3 -m pip",
      "cargo build",
      "cargo install",
      "cargo run",
      "make install",
      "chmod",
      "chown",
      "chgrp",
      "mv",
      "cp",
      "mkdir",
      "rmdir",
      "touch",
      "curl",
      "wget",
      "ssh",
      "scp",
      "rsync",
      "tar",
      "unzip",
      "flatpak",
      "snap",
      "docker",
      "podman",
      "firewall-cmd",
      "ufw",
      "iptables",
      "crontab",
      "at"
    ],
    "notes": "These commands are not inherently dangerous but can have significant effects. The user should always know what is being installed, modified, or downloaded."
  },

  "blocked": {
    "_comment": "These commands are NEVER allowed, regardless of confirmation. The agent must refuse to run them.",
    "exact_commands": [
      "rm -rf /",
      "rm -rf /*",
      "rm -rf ~",
      "rm -rf ~/",
      "chmod 777 /",
      "chmod -R 777 /",
      "chown -R",
      "> /dev/sda",
      "dd if=/dev/zero of=/dev/sda",
      "mkfs.ext4 /dev/sda",
      "mkfs /dev/sda",
      "shred /dev/sda",
      "userdel root",
      "passwd root",
      "echo 'root::0:0:root:/root:/bin/bash' >> /etc/passwd",
      ":(){:|:&};:"
    ],
    "command_prefixes": [
      "rm -rf /",
      "mkfs",
      "shred",
      "userdel",
      "passwd root",
      "dd if=",
      "dd bs=",
      "> /dev/",
      "cat /dev/urandom >",
      ":(){ :|:",
      "sudo su -",
      "sudo -i",
      "sudo bash",
      "sudo sh"
    ],
    "pattern_contains": [
      "/dev/sda",
      "/dev/sdb",
      "/dev/nvme0",
      "/etc/shadow",
      "~/.ssh/id_",
      ".ssh/authorized_keys",
      "browser passwords",
      "keychain",
      "|base64|",
      ">/dev/null 2>&1 &",
      "curl | bash",
      "curl | sh",
      "wget -O- | bash",
      "wget -O- | sh"
    ],
    "notes": "These patterns match destructive disk operations, privilege escalation attempts, credential theft, and silent remote code execution. They are blocked absolutely."
  }
}
